# ── API keys ──────────────────────────────────────────────────────────────────
RAPIDAPI_KEY=your_rapidapi_key_here

# ── Telegram ───────────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_numeric_chat_id_here   # restrict bot to this chat

# ── Web portal ─────────────────────────────────────────────────────────────────
WEB_SECRET_KEY=change-me-to-a-random-string  # used to sign auth cookies
WEB_PASSWORD=                                 # leave empty to disable portal auth

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:////data/flatbot.db

# ── Behaviour ──────────────────────────────────────────────────────────────────
SCAN_INTERVAL_MINUTES=30
LOG_LEVEL=INFO
MOCK_API=false                                # set true to use fixture data (no API calls)
WEB_API_URL=http://web:8000                   # bot → web service URL (Docker internal)
